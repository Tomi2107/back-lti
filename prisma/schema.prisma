generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {

 id String @id @default(uuid())

 moodle_user_sub String @unique

 accessibility_settings Json @default("{}")

 onboarding_completed Boolean @default(false)

 created_at DateTime @default(now())
 updated_at DateTime @updatedAt

 sessions Session[]

 @@map("users")
}

model Session {
  id                       String     @id @default(uuid())
  session_id               String     @unique @default(uuid())
  moodle_user_sub          String
  moodle_course_id         String?
  started_at               DateTime   @default(now())
  ended_at                 DateTime?
  user_agent               String     @default("")
  ip_address               String?
  city                     String?
  focus_mode_activated     Boolean    @default(false)
  focus_mode_total_seconds Int        @default(0)
  events                   EventLog[]
  user                     User       @relation(fields: [moodle_user_sub], references: [moodle_user_sub])

  @@index([moodle_user_sub])
  @@map("sessions")
}

model EventLog {
  id         String   @id @default(uuid())
  event_id   String   @unique @default(uuid())
  session_id String
  event_type String
  payload    Json     @default("{}")
  resultado  String
  timestamp  DateTime @default(now())
  session    Session  @relation(fields: [session_id], references: [session_id])

  @@index([session_id])
  @@map("event_logs")
}

model AiCache {
  id                String   @id @default(uuid())
  text_hash         String   @unique
  activity_id       String
  generated_summary String?
  simplified_text   String?
  key_concepts      Json?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("ai_caches")
}

model MoodleCourseCache {
  id               String   @id @default(uuid())
  activity_id      String   @unique
  moodle_course_id String?
  content_text_raw String?
  fetched_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("moodle_course_caches")
}

model UserProgress {
  id                         String    @id @default(uuid())
  moodle_user_sub            String
  moodle_activity_id         String
  moodle_course_id           String?
  status                     String    @default("PENDING")
  due_date                   DateTime?
  last_interaction_timestamp DateTime?

  @@unique([moodle_user_sub, moodle_activity_id])
  @@index([moodle_user_sub])
  @@map("user_progresses")
}

model SequelizeMeta {
  name String @id @db.VarChar(255)
}

model accesstokens {
  id          Int      @id @default(autoincrement())
  platformUrl String?
  clientId    String?
  scopes      String?
  iv          String?
  data        String?
  createdAt   DateTime @db.Timestamptz(6)
  updatedAt   DateTime @db.Timestamptz(6)

  @@unique([platformUrl, clientId, scopes], map: "accesstokens_platform_url_client_id_scopes")
  @@index([createdAt], map: "accesstokens_created_at")
}

model contexttokens {
  id                  Int      @id @default(autoincrement())
  contextId           String?
  path                String?
  user                String?
  roles               String[]
  targetLinkUri       String?
  context             Json?    @db.Json
  resource            Json?    @db.Json
  custom              Json?    @db.Json
  endpoint            Json?    @db.Json
  namesRoles          Json?    @db.Json
  lis                 Json?    @db.Json
  launchPresentation  Json?    @db.Json
  messageType         String?
  version             String?
  deepLinkingSettings Json?    @db.Json
  createdAt           DateTime @db.Timestamptz(6)
  updatedAt           DateTime @db.Timestamptz(6)

  @@index([contextId, user], map: "contexttokens_context_id_user")
  @@index([createdAt], map: "contexttokens_created_at")
}

model idtokens {
  id           Int      @id @default(autoincrement())
  iss          String?
  platformId   String?
  clientId     String?
  deploymentId String?
  user         String?
  userInfo     Json?    @db.Json
  platformInfo Json?    @db.Json
  createdAt    DateTime @db.Timestamptz(6)
  updatedAt    DateTime @db.Timestamptz(6)

  @@index([createdAt], map: "idtokens_created_at")
  @@index([iss, clientId, deploymentId, user], map: "idtokens_iss_client_id_deployment_id_user")
}

model nonces {
  nonce     String   @id @unique(map: "nonces_nonce") @db.VarChar(255)
  createdAt DateTime @db.Timestamptz(6)
  updatedAt DateTime @db.Timestamptz(6)

  @@index([createdAt], map: "nonces_created_at")
}

model platformStatuses {
  id        String   @id @unique(map: "platform_statuses_id") @db.VarChar(255)
  active    Boolean? @default(false)
  createdAt DateTime @db.Timestamptz(6)
  updatedAt DateTime @db.Timestamptz(6)
}

model platforms {
  id                  Int      @id @default(autoincrement())
  platformName        String?
  platformUrl         String?
  clientId            String?
  authEndpoint        String?
  accesstokenEndpoint String?
  kid                 String?  @unique(map: "platforms_kid")
  authConfig          Json?    @db.Json
  createdAt           DateTime @db.Timestamptz(6)
  updatedAt           DateTime @db.Timestamptz(6)
  authorizationServer String?  @db.VarChar(255)

  @@unique([platformUrl, clientId], map: "platforms_platform_url_client_id")
  @@index([platformUrl], map: "platforms_platform_url")
}

model privatekeys {
  kid         String   @id @unique(map: "privatekeys_kid") @db.VarChar(255)
  platformUrl String?
  clientId    String?
  iv          String?
  data        String?
  createdAt   DateTime @db.Timestamptz(6)
  updatedAt   DateTime @db.Timestamptz(6)
}

model publickeys {
  kid         String   @id @unique(map: "publickeys_kid") @db.VarChar(255)
  platformUrl String?
  clientId    String?
  iv          String?
  data        String?
  createdAt   DateTime @db.Timestamptz(6)
  updatedAt   DateTime @db.Timestamptz(6)
}

model states {
  state     String   @id @unique(map: "states_state") @db.VarChar(255)
  query     Json?    @db.Json
  createdAt DateTime @db.Timestamptz(6)
  updatedAt DateTime @db.Timestamptz(6)

  @@index([createdAt], map: "states_created_at")
}
