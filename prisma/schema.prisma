generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}


datasource db {
  provider = "postgresql"
}



model User {

  id String @id @default(uuid())

  moodle_user_sub String @unique

  onboarding_completed Boolean @default(false)

  created_at DateTime @default(now())

  updated_at DateTime @updatedAt


  sessions Session[]

  profiles AccessibilityProfile[]


  @@map("users")

}



model Session {

  id String @id @default(uuid())

  session_id String @unique @default(uuid())


  moodle_user_sub String

  moodle_course_id String?


  started_at DateTime @default(now())

  ended_at DateTime?


  user_agent String @default("")

  ip_address String?

  city String?


  focus_mode_activated Boolean @default(false)

  focus_mode_total_seconds Int @default(0)


  events EventLog[]


  user User @relation(fields: [moodle_user_sub], references: [moodle_user_sub])


  @@index([moodle_user_sub])

  @@map("sessions")

}



model EventLog {

  id String @id @default(uuid())


  event_id String @unique @default(uuid())


  session_id String


  event_type String


  payload Json @default("{}")


  resultado String


  timestamp DateTime @default(now())


  session Session @relation(fields: [session_id], references: [session_id])


  @@index([session_id])

  @@map("event_logs")

}



model AiCache {

  id String @id @default(uuid())


  text_hash String @unique


  activity_id String


  generated_summary String?

  simplified_text String?

  key_concepts Json?


  created_at DateTime @default(now())

  updated_at DateTime @updatedAt


  @@map("ai_caches")

}



model MoodleCourseCache {

  id String @id @default(uuid())


  activity_id String @unique


  moodle_course_id String?


  content_text_raw String?


  fetched_at DateTime @default(now())

  updated_at DateTime @updatedAt


  @@map("moodle_course_caches")

}



model UserProgress {

  id String @id @default(uuid())


  moodle_user_sub String


  moodle_activity_id String


  moodle_course_id String?


  status String @default("PENDING")


  due_date DateTime?


  last_interaction_timestamp DateTime?


  @@unique([moodle_user_sub, moodle_activity_id])


  @@index([moodle_user_sub])


  @@map("user_progresses")

}



model AccessibilityProfile {

  id String @id @default(uuid())


  userId String


  name String


  settings Json @default("{}")


  created_at DateTime @default(now())


  updated_at DateTime @updatedAt


  user User @relation(fields: [userId], references: [id], onDelete: Cascade)


  @@unique([userId, name])


  @@map("accessibility_profiles")

}