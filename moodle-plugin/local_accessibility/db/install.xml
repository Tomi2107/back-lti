<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/accessibility/db" VERSION="20240101" COMMENT="Plugin de accesibilidad LTI">
  <TABLES>
    <!-- Las preferencias se almacenan en el backend LTI (MongoDB).
         Esta tabla guarda únicamente el mapping userId↔moodleUserId
         para referencia local. -->
    <TABLE NAME="local_accessibility_users" COMMENT="Registro de usuarios que activaron la herramienta">
      <FIELDS>
        <FIELD NAME="id"         TYPE="int"  LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid"     TYPE="int"  LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="userid"  TYPE="unique"  FIELDS="userid"/>
      </KEYS>
    </TABLE>
  </TABLES>
</XMLDB>
