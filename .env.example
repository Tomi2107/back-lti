# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=https://your-backend.example.com

# ─── Seguridad ───────────────────────────────────────────────────────────────
# Clave de cifrado para ltijs — mínimo 32 chars aleatorios
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LTI_KEY=replace_with_64_hex_chars_generated_by_crypto_randomBytes

# ─── Base de datos ───────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/lti_accessibility

# ─── Plataforma LMS (Canvas, Moodle, etc.) ───────────────────────────────────
# Registra una plataforma por conjunto de vars (una sola por ahora)
PLATFORM_URL=https://lms.example.com
PLATFORM_NAME=Mi LMS
PLATFORM_CLIENT_ID=client_id

# Canvas: /api/lti/authorize_redirect
# Moodle: /mod/lti/auth.php
PLATFORM_AUTH_ENDPOINT=https://lms.example.com/api/lti/authorize_redirect

# Canvas: /login/oauth2/token
# Moodle: /mod/lti/token.php
PLATFORM_TOKEN_ENDPOINT=https://lms.example.com/login/oauth2/token

# Canvas: /api/lti/security/jwks
# Moodle: /mod/lti/certs.php
PLATFORM_KEYSET_ENDPOINT=https://lms.example.com/api/lti/security/jwks

# ─── CORS ────────────────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma (la direccion del front)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.example.com
